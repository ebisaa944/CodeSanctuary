# Render example environment variables (do NOT commit real secrets)
DATABASE_URL=postgres://postgres:password@<host>:5432/therapeutic
REDIS_URL=redis://:<password>@<host>:6379
SECRET_KEY=replace-me-with-secure-key
DJANGO_SETTINGS_MODULE=therapeutic_coding.settings.production
WEB_CONCURRENCY=2
ALLOWED_HOSTS=your-service.onrender.com
CSRF_TRUSTED_ORIGINS=https://your-service.onrender.com
RENDER_EXTERNAL_HOSTNAME=your-service.onrender.com
GUNICORN_TIMEOUT=120
GUNICORN_LOG_LEVEL=info
