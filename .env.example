### Code Sanctuary (.env.example)
# Copy to .env and update values for your environment.

# Django
DJANGO_SECRET_KEY=replace-me-with-a-secure-key
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database (example Postgres URL) - optional, defaults to sqlite if unset
DATABASE_URL=postgres://user:password@localhost:5432/codesanctuary

# Redis (used for cache, channel layer, presence)
REDIS_URL=redis://127.0.0.1:6379/1
REDIS_KEY_PREFIX=cs:
PRESENCE_TTL=45

# JWT settings
JWT_ACCESS_MINUTES=60
JWT_REFRESH_DAYS=7
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_SECONDS=3600

# Channels / ASGI
ASGI_APPLICATION=therapeutic_coding.asgi.application
CHANNEL_LAYERS_BACKEND=channels_redis.core.RedisChannelLayer

# Django REST Framework throttling
DRF_ANON_RATE=10/min
DRF_USER_RATE=60/min
DRF_PRESENCE_RATE=30/min

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Logging
DJANGO_LOG_LEVEL=INFO
